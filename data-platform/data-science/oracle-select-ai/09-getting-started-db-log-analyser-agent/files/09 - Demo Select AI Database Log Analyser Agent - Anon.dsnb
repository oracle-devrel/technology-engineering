},"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Create Email Notification Task","message":["%script","","-- Create Email Notification Task","BEGIN","  DBMS_CLOUD_AI_AGENT.create_task(","    task_name => 'EMAIL_LOGS_REPORT_TASK',","    attributes => '{\"instruction\": \"Send an email to the DB Operations team containing the following report: {query} ' ||","                  'Start the email with - Hi DB Operations Team,\\n' ||","                  'End the email with - \\nMany thanks,\\nIssy and Thomas\",","        \"input\" : \"ANALYZE_LOGS_TASK\",","        \"tools\": [\"LOG_REPORT_EMAIL_TOOL\"]","    }'","  );","END;","/"],"enabled":true,"result":{"startTime":1776967013363,"interpreter":"script.medium","endTime":1776967013898,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Drop Agent Team","message":["%script","","-- Drop Agents Team","BEGIN","    DBMS_CLOUD_AI_AGENT.DROP_TEAM('OPS_ISSUES_SOLUTION_TEAM');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Agent Team does not exist.');","END;","/"],"enabled":true,"result":{"startTime":1776967025718,"interpreter":"script.medium","endTime":1776967026966,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicForm