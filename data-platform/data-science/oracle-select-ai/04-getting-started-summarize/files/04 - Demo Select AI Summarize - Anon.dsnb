[{"layout":"zeppelin","isRunnable":true,"template":"dsrgmn3y","templateConfig":"{\"visualization\":{\"filters\":[{\"_id\":1583324064459,\"type\":\"styling\",\"enabled\":true,\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"hiddenConnection\",\"operator\":\"*\",\"value\":\"\"}]},\"component\":\"edge\",\"target\":\"edge\",\"properties\":{\"colors\":[\"rgba(0, 0, 0, 0.1)\"],\"style\":[\"dashed\"],\"legendTitle\":[\"Hidden Connection\"]}},{\"_id\":1590499315755,\"type\":\"aggregation\",\"enabled\":true,\"conditions\":{\"operator\":\"and\",\"conditions\":[]},\"component\":\"vertex\",\"target\":\"vertex\",\"properties\":{},\"aggregation\":[{\"source\":\"\",\"type\":\"average\"}]}],\"version\":4}}","isEditable":true,"name":"04 - Demo Select AI Summarize - Anon","description":null,"type":"medium","paragraphs":[{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":null,"message":["%md ","<center><h2 style='color:#0873d1'>Select AI - Summarize <h2><\/center>"],"enabled":true,"result":{"startTime":1770400462131,"interpreter":"md.medium","endTime":1770400462526,"results":[{"message":"<center><h2 style='color:#0873d1'>Select AI - Summarize <h2><\/center>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":12,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":"Pre-Requisites - Configuring Select AI","message":["%md","","<b>Note:<\/b> Please refer to the `\"00 - Setup Select AI - Anon\"` Notebook for all pre-requisites on granting permissions to Packages, LLMs, Authentication and for Setting Up Credentials."],"enabled":true,"result":{"startTime":1776961541831,"interpreter":"md.medium","endTime":1776961542283,"results":[{"message":"<p><b>Note:<\/b> Please refer to the <code>&quot;00 - Setup Select AI - Anon&quot;<\/code> Notebook for all pre-requisites on granting permissions to Packages, LLMs, Authentication and for Setting Up Credentials.<\/p>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":12,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Define OCI API Credential","message":["%script","","-- Drop Credential","BEGIN","    DBMS_CLOUD.DROP_CREDENTIAL('<enter-oci-api-credential-name>');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Credential does not exist.');","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create Credentials for OCI API Key","BEGIN                                                                          ","\tDBMS_CLOUD.CREATE_CREDENTIAL","        (  ","\t\t    \tcredential_name => '<enter-oci-api-credential-name>',","\t\t\t \tuser_ocid \t\t=> '<enter-user-ocid>',","\t\t        tenancy_ocid    => '<enter-tenancy-ocid>',","\t\t        private_key     => '<enter-private-key-value>',","\t\t        fingerprint     => '<enter-private-key-fingerprint>'       ","        );                                                                           ","END;                                                                           ","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Defining AI Profile - OCI GenAI","message":["%script","","-- Drop AI Profile","BEGIN","     DBMS_CLOUD_AI.DROP_PROFILE(profile_name => '<enter-ai-profile-name>');","EXCEPTION","     WHEN OTHERS THEN","          DBMS_OUTPUT.PUT_LINE('Profile does not exist.');","END;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create AI Profile using OCI GenAI and API Credentials","BEGIN                                                                          ","\tDBMS_CLOUD_AI.CREATE_PROFILE","        (                                                ","\t\t        profile_name => '<enter-ai-profile-name>'","\t\t    ,   attributes   => '{","                                        \"provider\"          : \"oci\"","\t\t                            ,   \"object_list\"       : ","                                                                [","                                                                        {\"owner\": \"SH\", \"name\": \"SALES\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"CUSTOMERS\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"CHANNELS\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"PRODUCTS\"}","                                                                ]","                                    ,   \"credential_name\"   : \"<enter-oci-api-credential-name>\"","                                    ,   \"model\"             : \"<enter-model-name-id>\"","                                    ,   \"oci_compartment_id\": \"<enter-oci-compartment-ocid>\"","                                    ,   \"region\"            : \"<enter-region-identifier>\"","                                    ,   \"comments\"          : \"true\"","                                    ,   \"conversation\"      : \"true\"","                                }'","        );","END;                                                                           ","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Set & View AI Profile","message":["%script","","-- Set AI Profile","EXEC DBMS_CLOUD_AI.SET_PROFILE('<enter-ai-profile-name>');"],"enabled":true,"result":{"startTime":1771516384189,"interpreter":"script.medium","endTime":1771516388977,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"table","title":null,"message":["%sql","","-- Get active AI Profile","SELECT DBMS_CLOUD_AI.GET_PROFILE() from dual;"],"enabled":true,"result":{"startTime":1771516401347,"interpreter":"sql.medium","endTime":1771516401786,"results":null,"taskStatus":null,"forms":null,"status":null},"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"SUMMARIZE - Generate Text Summaries","message":["%script","","-- If your text contains empty double quotes (\"\"), enclose the text using q'[]' mechanism. ","select ai summarize q'[Oracle Corporation is an American multinational technology company headquartered in Austin, Texas.[5] Co-founded in 1977 in Santa Clara, California, by its current chairman of the board and chief technology officer Larry Ellison,[6][7] Oracle is among the 20 largest companies in the world[8] by market cap, and ranked 66th[9] on the Forbes Global 2000 as of 2025. The company sells database software (particularly the Oracle Database), enterprise applications, and cloud infrastructure and hardware. Oracles core application software is a suite of enterprise software products, including enterprise resource planning (ERP), human capital management (HCM), customer relationship management (CRM), enterprise performance management (EPM), Customer Experience Commerce (CX Commerce) and supply chain management (SCM) software.[10] History See also- List of acquisitions by Oracle Larry Ellison, executive chairman and co-founder of Oracle Oracle Corporations former headquarters in Redwood Shores, California USA 17 at Oracle Corporation Headquarters Picture of the Oracle Austin Riverside Campus in 2018 Larry Ellison, Bob Miner, and Ed Oates co-founded Oracle in 1977 in Santa Clara, California, as Software Development Laboratories (SDL).[2][11] Beginning as consultants with a background in large-scale memory after a project for Ampex,[12] Ellison took inspiration[13] from the 1970 paper written by Edgar F. Codd on relational database management systems (RDBMS) named A Relational Model of Data for Large Shared Data Banks.[14] He heard about the IBM System R database[12] from an article in an IBM research journal provided by Oates. Ellison wanted to make Oracles product compatible with System R, but failed to do so as IBM kept the error codes for their DBMS a secret. SDL changed its name to Relational Software, Inc (RSI) in 1979,[15] then again to Oracle Systems Corporation in 1983,[16] to align itself more closely with its flagship product Oracle Database. The name also drew from the codename of a 1977 project for the Central Intelligence Agency, Oracles first customer[17][18][11] the company received permission to use the code name for the new product.[12] (According to Oracle executive Mike Humphries, Miner told him that the new company had the choice of the CIA database project or another offer to develop a compiler for the PDP-4, and the founders flipped a coin to decide.)[19] Miner served as a senior programmer, and Oates also worked in development. The three founders decided that Ellison was the worst programmer so he became the salesman. Understanding both customers and technology, Ellison designed database tables that he used to demonstrate the power of SQL to customers.[12] By February 1983 the Rosen Electronics Letter said that Oracle was the most comprehensive offering weve seen among databases, with good marketing and a substantial installed base encouraging developers to write software for it. The newsletter said that revenue in fiscal 1983 would be about $8 million and would double in 1984.[20] On March 12, 1986, the company had its initial public offering.[21] In 1989, Oracle moved its world headquarters to the Redwood Shores neighborhood of Redwood City, California, though its campus[22] was not completed until 1995.[23] The company hired so many from top universities that Humphries compared it to Cargill buying crops. Some new employees worked as receptionists or distributed coffee until more suitable positions became available.]'"],"enabled":true,"result":{"startTime":1771516776349,"interpreter":"script.medium","endTime":1771516780732,"results":[{"message":"\nRESPONSE                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             \nOracle Corporation is a multinational technology company headquartered in Austin, Texas, co-founded in 1977 by Larry Ellison, Bob Miner, and Ed Oates. The company sells database software, enterprise applications, and cloud infrastructure, with its core application software including enterprise resource planning, human capital management, and customer relationship management. Oracle was initially named Software Development Laboratories and later changed its name to Relational Software, Inc. and then Oracle Systems Corporation to align with its flagship product, Oracle Database. The company had its initial public offering in 1986 and moved its headquarters to Redwood City, California in 1989. Oracle has become one of the largest companies in the world, ranked 66th on the Forbes Global 2000 as of 2025, with a market cap among the top 20 companies globally.    \n\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":"[{\"raw\":{\"lastColumns\":[],\"version\":1}}]","hideInIFrame":false,"selectedVisualization":"raw","title":"Use SUMMARIZE Function - Text Input","message":["%script","set long 5000","","-- Call Summarize Function with Text Input","SELECT DBMS_CLOUD_AI.SUMMARIZE(","  content         => 'Oracle Corporation is an American multinational technology company headquartered in Austin, Texas.[5] Co-founded in 1977 in Santa Clara, California, by its current chairman of the board and chief technology officer Larry Ellison,[6][7] Oracle is among the 20 largest companies in the world[8] by market cap, and ranked 66th[9] on the Forbes Global 2000 as of 2025. The company sells database software (particularly the Oracle Database), enterprise applications, and cloud infrastructure and hardware. Oracles core application software is a suite of enterprise software products, including enterprise resource planning (ERP), human capital management (HCM), customer relationship management (CRM), enterprise performance management (EPM), Customer Experience Commerce (CX Commerce) and supply chain management (SCM) software.[10] History See also- List of acquisitions by Oracle Larry Ellison, executive chairman and co-founder of Oracle Oracle Corporations former headquarters in Redwood Shores, California USA 17 at Oracle Corporation Headquarters Picture of the Oracle Austin Riverside Campus in 2018 Larry Ellison, Bob Miner, and Ed Oates co-founded Oracle in 1977 in Santa Clara, California, as Software Development Laboratories (SDL).[2][11] Beginning as consultants with a background in large-scale memory after a project for Ampex,[12] Ellison took inspiration[13] from the 1970 paper written by Edgar F. Codd on relational database management systems (RDBMS) named A Relational Model of Data for Large Shared Data Banks.[14] He heard about the IBM System R database[12] from an article in an IBM research journal provided by Oates. Ellison wanted to make Oracles product compatible with System R, but failed to do so as IBM kept the error codes for their DBMS a secret. SDL changed its name to Relational Software, Inc (RSI) in 1979,[15] then again to Oracle Systems Corporation in 1983,[16] to align itself more closely with its flagship product Oracle Database. The name also drew from the codename of a 1977 project for the Central Intelligence Agency, Oracles first customer[17][18][11] the company received permission to use the code name for the new product.[12] (According to Oracle executive Mike Humphries, Miner told him that the new company had the choice of the CIA database project or another offer to develop a compiler for the PDP-4, and the founders flipped a coin to decide.)[19] Miner served as a senior programmer, and Oates also worked in development. The three founders decided that Ellison was the worst programmer so he became the salesman. Understanding both customers and technology, Ellison designed database tables that he used to demonstrate the power of SQL to customers.[12] By February 1983 the Rosen Electronics Letter said that Oracle was the most comprehensive offering weve seen among databases, with good marketing and a substantial installed base encouraging developers to write software for it. The newsletter said that revenue in fiscal 1983 would be about $8 million and would double in 1984.[20] On March 12, 1986, the company had its initial public offering.[21] In 1989, Oracle moved its world headquarters to the Redwood Shores neighborhood of Redwood City, California, though its campus[22] was not completed until 1995.[23] The company hired so many from top universities that Humphries compared it to Cargill buying crops. Some new employees worked as receptionists or distributed coffee until more suitable positions became available.',","  profile_name    => '<enter-ai-profile-name>',","  params          => '{\"max_words\":\"500\",","                        \"min_words\":\"100\",","                        \"summary_style\":\"paragraph\",","                        \"chunk_processing_method\": \"map_reduce\",","                        \"extractiveness_level\":\"medium\"","                      }',","  user_prompt     => 'The summary should start with ''The summary of '",") AS RESPONSE","FROM DUAL;"],"enabled":true,"result":{"startTime":1771519367613,"interpreter":"script.medium","endTime":1771519375706,"results":[{"message":"\n---------------------------\n\nRESPONSE                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            \nThe summary of Oracle Corporation is that it is an American multinational technology company headquartered in Austin, Texas, co-founded in 1977 by Larry Ellison, who is the current chairman of the board and chief technology officer. Oracle is among the 20 largest companies in the world by market cap and ranked 66th on the Forbes Global 2000 as of 2025. The company sells database software, enterprise applications, and cloud infrastructure and hardware, with its core application software being a suite of enterprise software products, including enterprise resource planning, human capital management, customer relationship management, and supply chain management software. Oracle was initially founded as Software Development Laboratories in Santa Clara, California, and later changed its name to Relational Software, Inc, and then to Oracle Systems Corporation to align itself with its flagship product, Oracle Database. The company's name was inspired by a 1977 project for the Central Intelligence Agency, and it received permission to use the code name for its new product. Oracle had its initial public offering in 1986 and moved its world headquarters to Redwood City, California, in 1989. The company has grown significantly over the years, hiring many employees from top universities, and has become a leading provider of enterprise software solutions. With a substantial installed base and good marketing, Oracle's revenue has increased significantly, and it continues to be a major player in the technology industry. The company's history is marked by its commitment to innovation and customer satisfaction, and it has established itself as a leader in the field of relational database management systems. Overall, Oracle Corporation is a successful and influential technology company with a rich history and a strong presence in the industry.    \n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Define OCI Auth Token Credential","message":["%script","","-- Drop Credential","BEGIN","    DBMS_CLOUD.DROP_CREDENTIAL('<enter-oci-auth-token-credential-name>');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Credential does not exist.');","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["","%script","","-- Create Credential for OCI Authentication Token","BEGIN                                                                          ","\tDBMS_CLOUD.CREATE_CREDENTIAL","        (  ","\t\t        credential_name => '<enter-oci-auth-token-credential-name>'","\t\t    ,   username        => '<domain-name>/<enter-oci-user>'","\t\t    ,   password        => '<enter-oci-auth-token>'","        );                                                                           ","END;                                                                           ","/"," "],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Use SUMMARIZE Function - Object Storage Input","message":["%script","set long 5000","","-- Call Summarize Function with Object Storage Input","SELECT DBMS_CLOUD_AI.SUMMARIZE(","                location_uri    => '<enter-file-object-storage-uri>',","                credential_name => '<enter-oci-auth-token-credential-name>',","                profile_name    => '<enter-ai-profile-name>',","                params          => '{\"max_words\":\"500\",","                                    \"min_words\":\"100\",","                                    \"summary_style\":\"list\",","                                    \"chunk_processing_method\": \"iterative_refinement\",","                                    \"extractiveness_level\":\"medium\"","                                }',","                user_prompt     => 'The summary should start with - The summary of..') AS RESPONSE","FROM DUAL;"," "],"enabled":true,"result":{"startTime":1771519398946,"interpreter":"script.medium","endTime":1771519528994,"results":[{"message":"\n---------------------------\n\nRESPONSE                                                                                                                                                                                                                                                                                                                                          \n- The summary of the Oracle AI Vector Search User's Guide and related concepts is a comprehensive document that provides information on querying semantic and business data with Oracle AI Vector Search, which is designed for Artificial Intelligence (AI) workloads and allows users to query data based on semantics rather than keywords.\n- Oracle AI Vector Search introduces the VECTOR data type, which provides the foundation to store vector embeddings alongside business data in the database, enabling users to combine semantic search on unstructured data with relational search on business data in one single system.\n- Vector embeddings are mathematical vector representations of data points that describe the semantic meaning behind content such as words, documents, audio tracks, or images, and Oracle AI Vector Search stores and indexes vector embeddings for fast retrieval and similarity search.\n- The guide covers topics such as generating vector embeddings, accessing third-party models for vector generation, and using Vector Utility PL/SQL packages to perform chunking, embedding, and text generation operations, as well as Vector Search PL/SQL packages, including DBMS_VECTOR and DBMS_VECTOR_CHAIN.\n- Oracle AI Vector Search provides various parameters for chunking text data and allows users to create custom vocabulary and language data for chunking, and it supports ONNX embedding models that conform to specific input and output formats.\n- The guide includes examples and use cases to help users understand how to use Oracle AI Vector Search to generate vector embeddings, perform similarity searches, and integrate with other Oracle technologies, such as Oracle Text and Oracle Machine Learning.\n- Additionally, the guide covers advanced topics, including hybrid vector indexes, which combine traditional keyword-based text search with vector-based similarity search, and Retrieval-Augmented Generation, a technique for enhancing the accuracy of responses generated by Large Language Models.\n- Key concepts related to Oracle AI Vector Search include vector distance, vector embedding, vector index, and similarity search, which are essential for understanding how the technology works and how to apply it in various scenarios.\n- The EmbeddingModel class is used to convert transformer models to the ONNX format with post-processing steps embedded into the final model, and it provides parameters such as model_name, configuration, and settings to control various operations.\n- The guide also provides information on creating sharded and duplicated tables with vector columns in a Globally Distributed Database and using BINARY vectors and sparse vectors in Oracle AI Vector Search, which can help improve storage efficiency and query performance.    \n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":null,"message":["%md ","<center><h2 style='color:#0873d1'>End of Notebook <h2><\/center>"],"enabled":true,"result":{"startTime":1771517119787,"interpreter":"md.medium","endTime":1771517120171,"results":[{"message":"<center><h2 style='color:#0873d1'>End of Notebook <h2><\/center>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"}],"version":"7","snapshot":false,"tags":null}]