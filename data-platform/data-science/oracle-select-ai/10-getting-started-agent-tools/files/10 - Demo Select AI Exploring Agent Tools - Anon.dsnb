[{"layout":"zeppelin","isRunnable":true,"template":"dsrgmn3y","templateConfig":"{\"visualization\":{\"filters\":[{\"_id\":1583324064459,\"type\":\"styling\",\"enabled\":true,\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"hiddenConnection\",\"operator\":\"*\",\"value\":\"\"}]},\"component\":\"edge\",\"target\":\"edge\",\"properties\":{\"colors\":[\"rgba(0, 0, 0, 0.1)\"],\"style\":[\"dashed\"],\"legendTitle\":[\"Hidden Connection\"]}},{\"_id\":1590499315755,\"type\":\"aggregation\",\"enabled\":true,\"conditions\":{\"operator\":\"and\",\"conditions\":[]},\"component\":\"vertex\",\"target\":\"vertex\",\"properties\":{},\"aggregation\":[{\"source\":\"\",\"type\":\"average\"}]}],\"version\":4}}","isEditable":true,"name":"10 - Demo Select AI - Exploring Agent Tools - Anon","description":null,"type":"medium","paragraphs":[{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":null,"message":["%md ","<center><h2 style='color:#0873d1'>Select AI - Exploring Agent Tools<h2><\/center>"],"enabled":true,"result":{"startTime":1777027941104,"interpreter":"md.medium","endTime":1777027941408,"results":[{"message":"<center><h2 style='color:#0873d1'>Select AI - Exploring Agent Tools<h2><\/center>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":"Pre-Requisites - Configuring Select AI","message":["%md","","<b>Note:<\/b> Please refer to the `\"00 - Setup Select AI - Anon\"` Notebook for all pre-requisites on granting permissions to Packages, LLMs, Authentication and for Setting Up Credentials."],"enabled":true,"result":{"startTime":1777028137627,"interpreter":"md.medium","endTime":1777028138205,"results":[{"message":"<p><b>Note:<\/b> Please refer to the <code>&quot;00 - Setup Select AI - Anon&quot;<\/code> Notebook for all pre-requisites on granting permissions to Packages, LLMs, Authentication and for Setting Up Credentials.<\/p>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":"PL/SQL Function Tool","message":["%md","This example creates a PL/SQL Function tool that is able to call a PL/SQL Function that you have defined. The PL/SQL Function is able to take input, execute the code block and then returning the output back to the agentic workflow."," "],"enabled":true,"result":{"startTime":1777026566554,"interpreter":"md.medium","endTime":1777026566863,"results":[{"message":"<p>This example creates a PL/SQL Function tool that is able to call a PL/SQL Function that you have defined. The PL/SQL Function is able to take input, execute the code block and then returning the output back to the agentic workflow.<\/p>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Define PL/SQL Function","message":["%script","","-- Drop Function for fecthing logs","DROP FUNCTION IF EXISTS fetch_logs;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create a customized fetch_logs procedure","CREATE OR REPLACE FUNCTION fetch_logs(since_date IN DATE) RETURN CLOB AS","  ","  -- Declare variable","  l_logs CLOB;","","  BEGIN","    SELECT JSON_ARRAYAGG(log_message RETURNING CLOB)","      INTO l_logs","    FROM demo_agents_app_logs","    WHERE log_timestamp >= since_date","    ORDER BY log_timestamp;","","    RETURN l_logs;","","  EXCEPTION","    WHEN OTHERS THEN","      RETURN 'Error fetching logs: ' || SQLERRM;","","END fetch_logs;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Define PL/SQL Function Tool","message":["%script","","-- Drop Log Fetcher Tool","BEGIN","    DBMS_CLOUD_AI_AGENT.DROP_TOOL('LOG_FETCHER_TOOL');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Tool does not exist.');","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","--Create Log Fetcher Tool","BEGIN","    DBMS_CLOUD_AI_AGENT.CREATE_TOOL(","    tool_name => 'LOG_FETCHER_TOOL',","    attributes => '{\"instruction\": \"retrieves and returns all log messages with a LOG_TIMESTAMP greater than or equal to the input date.\",","                    \"function\": \"fetch_logs\"}'","    );","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":"SQL Tool","message":["%md","","This example creates a SQL tool that translates natural language queries into SQL statements. SQL tool helps the agents answer data-related questions by mapping prompts into SQL queries.<\/br><\/br>","","This example shows using OCI as the AI provider as specified in the AI profile named nl2sql_profile. The AI profile identifies the LLM the agent uses for reasoning and responses. In this example, the AI profile nl2sql_profile defines the set of SH schema tables that the agent can query, enabling natural language access to commonly used sales history data such as customers, products, promotions, and countries. The SQL tool uses the database objects that are specified in the AI profile, ensuring that generated SQL statements remain accurate and relevant to the SH data set."],"enabled":true,"result":{"startTime":1777024473232,"interpreter":"md.medium","endTime":1777024473559,"results":[{"message":"<p>This example creates a SQL tool that translates natural language queries into SQL statements. SQL tool helps the agents answer data-related questions by mapping prompts into SQL queries.<\/br><\/br><\/p>\n<p>This example shows using OCI as the AI provider as specified in the AI profile named nl2sql_profile. The AI profile identifies the LLM the agent uses for reasoning and responses. In this example, the AI profile nl2sql_profile defines the set of SH schema tables that the agent can query, enabling natural language access to commonly used sales history data such as customers, products, promotions, and countries. The SQL tool uses the database objects that are specified in the AI profile, ensuring that generated SQL statements remain accurate and relevant to the SH data set.<\/p>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Define OCI API Credential","message":["%script","","-- Drop Credential","BEGIN","    DBMS_CLOUD.DROP_CREDENTIAL('<enter-oci-api-credential-name>');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Credential does not exist.');","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create Credentials for OCI API Key","BEGIN                                                                          ","\tDBMS_CLOUD.CREATE_CREDENTIAL","        (  ","\t\t    \tcredential_name => '<enter-oci-api-credential-name>',","\t\t\t \tuser_ocid \t\t=> '<enter-user-ocid>',","\t\t        tenancy_ocid    => '<enter-tenancy-ocid>',","\t\t        private_key     => '<enter-private-key-value>',","\t\t        fingerprint     => '<enter-private-key-fingerprint>'       ","        );                                                                           ","END;                                                                           ","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Define AI Profile","message":["%script","","-- Drop AI Profile","BEGIN","     DBMS_CLOUD_AI.DROP_PROFILE(profile_name => '<enter-ai-profile-name>');","EXCEPTION","  WHEN OTHERS THEN","    DBMS_OUTPUT.PUT_LINE('Profile does not exist.');","END;"],"enabled":true,"result":{"startTime":1777024599919,"interpreter":"script.medium","endTime":1777024604773,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":null,"message":["%script","","-- Create AI Profile","BEGIN","    DBMS_CLOUD_AI.create_profile ","        (                                              ","                profile_name => '<enter-ai-profile-name>'","            ,   attributes   => '{","                                        \"provider\"          : \"oci\"","                                    ,   \"credential_name\"   : \"<enter-ai-api-credential-name>\"","                                    ,   \"object_list\"       : [","                                                                        {\"owner\": \"SH\", \"name\": \"CUSTOMERS\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"COUNTRIES\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"SUPPLEMENTARY_DEMOGRAPHICS\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"PROFITS\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"PROMOTIONS\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"PRODUCTS\"}","                                                              ]","                                    ,   \"region\"            : \"<enter-region-identifier>\"","                                    ,   \"model\"             : \"<enter-model-name-id>\"                                  ","                                    ,   \"oci_compartment_id\": \"<enter-compartment-ocid>\"","                                    ,   \"comments\"          : \"true\"","                                    ,   \"conversation\"      : \"true\"","                                }'","        );","END;","/"],"enabled":true,"result":{"startTime":1777024608976,"interpreter":"script.medium","endTime":1777024610659,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Define SQL Tool","message":["%script","","-- Drop SQL Tool","BEGIN","    DBMS_CLOUD_AI_AGENT.DROP_TOOL('SQL');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Tool does not exist.');","END;","/"],"enabled":true,"result":{"startTime":1777024708464,"interpreter":"script.medium","endTime":1777024709050,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":null,"message":["%script","","-- Create SQL Tool","BEGIN","  DBMS_CLOUD_AI_AGENT.CREATE_TOOL(","    tool_name  => 'SQL',","    attributes => '{\"tool_type\": \"SQL\",","                    \"tool_params\": {\"profile_name\": \"<enter-ai-profile-name>\"}}'","  );","END;","/"],"enabled":true,"result":{"startTime":1777024735027,"interpreter":"script.medium","endTime":1777024735656,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":"RAG Tool","message":["%md","","This example creates a RAG (Retrieval Augmented Generation) tool. The RAG tool lets agents retrieve and ground responses in enterprise documents, improving accuracy for knowledge-based answers.<\/br><\/br>","","This example illustrates defining a RAG_PROFILE with credentials, a vector index, and specifying profile parameters. Then, creating a vector index RAG_INDEX in Object Storage for document embeddings and creating the RAG_TOOL linked to your profile."],"enabled":true,"result":{"startTime":1777024760040,"interpreter":"md.medium","endTime":1777024760350,"results":[{"message":"<p>This example creates a RAG (Retrieval Augmented Generation) tool. The RAG tool lets agents retrieve and ground responses in enterprise documents, improving accuracy for knowledge-based answers.<\/br><\/br><\/p>\n<p>This example illustrates defining a RAG_PROFILE with credentials, a vector index, and specifying profile parameters. Then, creating a vector index RAG_INDEX in Object Storage for document embeddings and creating the RAG_TOOL linked to your profile.<\/p>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Define OCI API Credential","message":["%script","","-- Drop Credential","BEGIN","    DBMS_CLOUD.DROP_CREDENTIAL('<enter-oci-api-credential-name>');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Credential does not exist.');","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create Credentials for OCI API Key","BEGIN                                                                          ","\tDBMS_CLOUD.CREATE_CREDENTIAL","        (  ","\t\t    \tcredential_name => '<enter-oci-api-credential-name>',","\t\t\t \tuser_ocid \t\t=> '<enter-user-ocid>',","\t\t        tenancy_ocid    => '<enter-tenancy-ocid>',","\t\t        private_key     => '<enter-private-key-value>',","\t\t        fingerprint     => '<enter-private-key-fingerprint>'       ","        );                                                                           ","END;                                                                           ","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Define AI Profile","message":["%script","","-- Drop AI Profile","BEGIN","    DBMS_CLOUD_AI.DROP_PROFILE(profile_name => '<enter-ai-profile-name>');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Profile does not exist.');","END;","/"],"enabled":true,"result":{"startTime":1777024864165,"interpreter":"script.medium","endTime":1777024865078,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":null,"message":["%script","","-- Create AI Profile","BEGIN","    DBMS_CLOUD_AI.CREATE_PROFILE ","        (                                              ","                profile_name => '<enter-ai-profile-name>'","            ,   attributes   => '{","                                        \"provider\"          : \"oci\"","                                    ,   \"credential_name\"   : \"<enter-oci-api-credential-name>\"","                                    ,   \"region\"            : \"<enter-region-identifier>\"","                                    ,   \"model\"             : \"<enter-model-name-id>\"","                                    ,   \"temperature\"       : 0.2","                                    ,   \"max_tokens\"        : 1000","                                    ,   \"embedding_model\"   : \"<enter-embedding-model-name-id>\"","                                    ,   \"vector_index_name\" : \"<enter-vector-index-name>\"                                  ","                                    ,   \"oci_compartment_id\": \"<enter-compartment-ocid>\"","                                    ,   \"enable_sources\"    : true ","                                }'","        );","END;","/"],"enabled":true,"result":{"startTime":1777024870937,"interpreter":"script.medium","endTime":1777024872489,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Define OCI Auth Token Credential","message":["%script","","-- Drop Credential","BEGIN","    DBMS_CLOUD.DROP_CREDENTIAL('<enter-oci-auth-token-credential-name>');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Credential does not exist.');","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["","%script","","-- Create Credential for OCI Authentication Token","BEGIN                                                                          ","\tDBMS_CLOUD.CREATE_CREDENTIAL","        (  ","\t\t        credential_name => '<enter-oci-auth-token-credential-name>'","\t\t    ,   username        => '<domain-name>/<enter-oci-user>'","\t\t    ,   password        => '<enter-oci-auth-token>'","        );                                                                           ","END;                                                                           ","/"," "],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Define Vector Index","message":["%script","","-- Drop Vector Index","BEGIN","    DBMS_CLOUD_AI.DROP_VECTOR_INDEX('<enter-vector-index-name>');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Vector Index does not exist.');","END;","/"],"enabled":true,"result":{"startTime":1777025039406,"interpreter":"script.medium","endTime":1777025041457,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":null,"message":["%script","","-- Create Vector Index","BEGIN","  DBMS_CLOUD_AI.CREATE_VECTOR_INDEX(","    index_name  => '<enter-vector-index-name>',","    attributes  => '{","                        \"vector_db_provider\": \"oracle\",","                        \"location\": \"<enter-object-storage-file-uri>\",","                        \"object_storage_credential_name\": \"<enter-oci-auth-token-credential-name>\",","                        \"profile_name\": \"<enter-ai-profile-name>\",","                        \"vector_dimension\": 1024,","                        \"vector_distance_metric\": \"cosine\",","                        \"chunk_overlap\":20,","                        \"chunk_size\":250,","                        \"match_limit\":3","                    }'","    );","END;"],"enabled":true,"result":{"startTime":1777025119954,"interpreter":"script.medium","endTime":1777025125218,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Define RAG Tool","message":["%script","","-- Drop RAG Tool","BEGIN","    DBMS_CLOUD_AI_AGENT.DROP_TOOL('RAG_TOOL');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Tool does not exist.');","END;","/"],"enabled":true,"result":{"startTime":1777025229951,"interpreter":"script.medium","endTime":1777025230400,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":null,"message":["%script","","BEGIN","  DBMS_CLOUD_AI_AGENT.CREATE_TOOL(","    tool_name  => 'RAG_TOOL',","    attributes => '{\"tool_type\": \"RAG\",","                    \"tool_params\": {\"profile_name\": \"<enter-ai-profile-name>\"}}'","  );","END;","/"],"enabled":true,"result":{"startTime":1777025233202,"interpreter":"script.medium","endTime":1777025233819,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":"Web Search Tool","message":["%md","","This example creates a Websearch tool for retrieving details from the internet. The Websearch tool enables agents to look up information from the web, such as product prices or descriptions.<\/br><\/br>","","This example illustrates adding an ACL entry for the OpenAI provider. Creating credentials OPENAI_CRED with your API key and creating the Websearch tool, describing its purpose, linking it to the credential.<\/br><\/br>","","Note - OpenAI is the only Websearch AI provider supported."],"enabled":true,"result":{"startTime":1777025361969,"interpreter":"md.medium","endTime":1777025362300,"results":[{"message":"<p>This example creates a Websearch tool for retrieving details from the internet. The Websearch tool enables agents to look up information from the web, such as product prices or descriptions.<\/br><\/br><\/p>\n<p>This example illustrates adding an ACL entry for the OpenAI provider. Creating credentials OPENAI_CRED with your API key and creating the Websearch tool, describing its purpose, linking it to the credential.<\/br><\/br><\/p>\n<p>Note - OpenAI is the only Websearch AI provider supported.<\/p>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Add ACL for OpenAI Provider","message":["%script","","-- Add ACL for OpenAI host","BEGIN","  DBMS_NETWORK_ACL_ADMIN.APPEND_HOST_ACE(","    host => 'api.openai.com',","    ace  => xs$ace_type(privilege_list => xs$name_list('http'),","                        principal_name => '<enter-schema-name>',","                        principal_type => xs_acl.ptype_db)","   );","END;","/"],"enabled":true,"result":{"startTime":1777025407986,"interpreter":"script.medium","endTime":1777025408624,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Define OpenAI Credentials","message":["%script","","BEGIN","    DBMS_CLOUD.DROP_CREDENTIAL('<enter-openai-credential-name>');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Credential does not exist.');","END;","/"],"enabled":true,"result":{"startTime":1777025457863,"interpreter":"script.medium","endTime":1777025458391,"results":[{"message":"\nPL/SQL procedure successfully completed.\n\n\n---------------------------\n","type":"TEXT"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":false,"width":0,"hideResul