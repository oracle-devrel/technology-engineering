[{"layout":"zeppelin","isRunnable":true,"template":"dsrgmn3y","templateConfig":"{\"visualization\":{\"filters\":[{\"_id\":1583324064459,\"type\":\"styling\",\"enabled\":true,\"conditions\":{\"operator\":\"and\",\"conditions\":[{\"property\":\"hiddenConnection\",\"operator\":\"*\",\"value\":\"\"}]},\"component\":\"edge\",\"target\":\"edge\",\"properties\":{\"colors\":[\"rgba(0, 0, 0, 0.1)\"],\"style\":[\"dashed\"],\"legendTitle\":[\"Hidden Connection\"]}},{\"_id\":1590499315755,\"type\":\"aggregation\",\"enabled\":true,\"conditions\":{\"operator\":\"and\",\"conditions\":[]},\"component\":\"vertex\",\"target\":\"vertex\",\"properties\":{},\"aggregation\":[{\"source\":\"\",\"type\":\"average\"}]}],\"version\":4}}","isEditable":true,"name":"07 - Demo Select AI Proxy Integration - Anon","description":null,"type":"medium","paragraphs":[{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":null,"message":["%md ","<center><h2 style='color:#0873d1'>Select AI - Proxy Integration with PostgreSQL<h2><\/center>"],"enabled":true,"result":{"startTime":1777021569600,"interpreter":"md.medium","endTime":1777021570083,"results":[{"message":"<center><h2 style='color:#0873d1'>Select AI - Proxy Integration with PostgreSQL<h2><\/center>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":"Pre-Requisites - Configuring Select AI","message":["%md","","<b>Note:<\/b> Please refer to the `\"00 - Setup Select AI - Anon\"` Notebook for all pre-requisites on granting permissions to Packages, LLMs, Authentication and for Setting Up Credentials."],"enabled":true,"result":{"startTime":1777022742914,"interpreter":"md.medium","endTime":1777022743435,"results":[{"message":"<p><b>Note:<\/b> Please refer to the <code>&quot;00 - Setup Select AI - Anon&quot;<\/code> Notebook for all pre-requisites on granting permissions to Packages, LLMs, Authentication and for Setting Up Credentials.<\/p>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Defining PostgreSQL Credential","message":["%script","","-- Drop Credential","BEGIN","    DBMS_CLOUD.DROP_CREDENTIAL(credential_name => '<enter-postgresql-credential-name>');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Credential does not exist.');","END;","/"," "],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create a credential that stores the PostgreSQL username and password.","BEGIN","    DBMS_CLOUD.CREATE_CREDENTIAL(","        credential_name => '<enter-postgresql-credential-name>',","        username        => '<enter-postgresql-user>',","        password        => '<enter-postgresql-password>'","    );","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Create Database Link to PostgreSQL DB","message":["%script","","-- Drop Database Link","BEGIN","    DBMS_CLOUD_ADMIN.DROP_DATABASE_LINK(db_link_name => '<enter-postgres-database-link-name>');","EXCEPTION","  WHEN OTHERS THEN","    DBMS_OUTPUT.PUT_LINE('Database Link does not exist.');","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create a heterogeneous database link to PostgreSQL. This example uses gateway_params to set the database type and SSL.","BEGIN","    DBMS_CLOUD_ADMIN.CREATE_DATABASE_LINK(","        db_link_name        => '<enter-postgresql-database-link-name>',","        hostname            => '<enter-postgresql-primary-endpoint-fqdn>',","        port                => 5432,","        service_name        => 'postgres',","        credential_name     => '<enter-postgresql-credential-name>',","        gateway_params      => JSON_OBJECT('db_type' VALUE 'postgres', 'enable_ssl' VALUE true),","        ssl_server_cert_dn  => NULL,","        private_target      => true","    );","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Define a Logical View on PostgreSQL Table","message":["%script","","-- Drop View of Exists","DROP VIEW IF EXISTS V_POSTGRESQL_LINK_SALES;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create a local view on the PostgreSQL table and map the remote PostgreSQL table into the Autonomous AI Database schema with a view.","CREATE VIEW V_POSTGRESQL_LINK_SALES AS (","    SELECT ","        *","    FROM ","        \"sales\"@postgresql_link",");"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Query View","SELECT","    COUNT(*)","FROM","    V_POSTGRESQL_LINK_SALES;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Directly Query PostgreSQL Data","SELECT","    COUNT(*)","FROM","    \"sales\"@postgresql_link;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Diretcly Query PostgreSQL Data    ","SELECT","    count(distinct \"prod_id\")","FROM","    \"sales\"@postgresql_link","WHERE","    \"channel_id\"=2;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Define OCI API Credential","message":["%script","","-- Drop Credential","BEGIN","    DBMS_CLOUD.DROP_CREDENTIAL('<enter-oci-api-credential-name>');","EXCEPTION","  WHEN OTHERS THEN","    DBMS_OUTPUT.PUT_LINE('Credential does not exist.');","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create Credentials for OCI API Key","BEGIN                                                                          ","\tDBMS_CLOUD.CREATE_CREDENTIAL","        (  ","\t\t    \tcredential_name => '<enter-oci-api-credential-name>',","\t\t\t \tuser_ocid \t\t=> '<enter-user-ocid>',","\t\t        tenancy_ocid    => '<enter-tenancy-ocid>',","\t\t        private_key     => '<enter-private-key>',","\t\t        fingerprint     => '<enter-enter-fingerprint>'       ","        );                                                                           ","END;                                                                           ","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Define AI Profile","message":["%script","","-- Drop AI Profile","BEGIN","     DBMS_CLOUD_AI.DROP_PROFILE(profile_name => '<enter-ai-profile-name>');","EXCEPTION","  WHEN OTHERS THEN","    DBMS_OUTPUT.PUT_LINE('Profile does not exist.');","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create AI Profile using OCI GenAI and API Credentials","BEGIN                                                                          ","\tDBMS_CLOUD_AI.CREATE_PROFILE","        (                                                ","\t\t        profile_name => '<enter-ai-profile-name>'","\t\t    ,   attributes   => '{","                                        \"provider\"          : \"oci\"","\t\t                            ,   \"object_list\"       : ","                                                                [","                                                                        {\"owner\": \"<enter-schema-name>\", \"name\": \"V_POSTGRESQL_LINK_SALES\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"CUSTOMERS\"}","                                                                ]","                                    ,   \"credential_name\"   : \"<enter-oci-api-credential-name>\"","                                    ,   \"model\"             : \"<enter-model-name-id>\"","                                    ,   \"oci_compartment_id\": \"<enter-compartment-id>\"","                                    ,   \"region\"            : \"<enter-region-identifier>\"","                                    ,   \"comments\"          : \"true\"","                                    ,   \"conversation\"      : \"true\"","                                    ,   \"enforce_object_list\": \"true\"","                                }'","        );","END;                                                                           ","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Set AI Profile","EXEC DBMS_CLOUD_AI.SET_PROFILE('<enter-ai-profile-name>');"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Query Oracle AI Database Table","message":["%script","","-- Call Select AI","SELECT AI HOW MANY CUSTOMERS DO WE HAVE; "],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Call Select AI","SELECT AI SHOWSQL HOW MANY CUSTOMERS DO WE HAVE;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Query PostgreSQL Proxy Tables","message":["%script","","-- Call Select AI - Proxy Object","SELECT AI WHAT IS THE TOTAL AMOUNT SOLD;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Call Select AI - Proxy Object","SELECT AI SHOWSQL WHAT IS THE TOTAL AMOUNT SOLD;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Query Across Both Data Sources","message":["%script","","-- Query across both data sources","SELECT DBMS_CLOUD_AI.GENERATE(prompt       => 'what is the total amount sold for married customers',","                              profile_name => '<enter-ai-profile-name>',","                              action       => 'runsql') RESPONSE","FROM dual;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Verify Query Results","SELECT ","    SUM(s.\"amount_sold\") AS \"TOTAL_AMOUNT_SOLD\"","FROM ","    \"V_POSTGRESQL_LINK_SALES\" s","    JOIN \"SH\".\"CUSTOMERS\" c ON s.\"cust_id\" = c.\"CUST_ID\"","WHERE ","    UPPER(c.\"CUST_MARITAL_STATUS\") = UPPER('married');"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":null,"message":["%md ","","<center><h2 style='color:#0873d1'>End of Notebook<h2><\/center>"],"enabled":true,"result":{"startTime":1777022564685,"interpreter":"md.medium","endTime":1777022565009,"results":[{"message":"<center><h2 style='color:#0873d1'>End of Notebook<h2><\/center>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"}],"version":"7","snapshot":false,"tags":null}]