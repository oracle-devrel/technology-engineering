e>&quot;00 - Setup Select AI - Anon&quot;<\/code> Notebook for all pre-requisites on granting permissions to Packages, LLMs, Authentication and for Setting Up Credentials.<\/p>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":12,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":true,"hideVizConfig":true,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Define OCI API Credential","message":["%script","","-- Drop Credential","BEGIN","    DBMS_CLOUD.DROP_CREDENTIAL('<enter-oci-api-credential-name>');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Credential does not exist.');","END;","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create Credentials for OCI API Key","BEGIN                                                                          ","\tDBMS_CLOUD.CREATE_CREDENTIAL","        (  ","\t\t    \tcredential_name => '<enter-oci-api-credential-name>',","\t\t\t \tuser_ocid \t\t=> '<enter-user-ocid>',","\t\t        tenancy_ocid    => '<enter-tenancy-ocid>',","\t\t        private_key     => '<enter-private-key-value>',","\t\t        fingerprint     => '<enter-private-key-fingerprint>'       ","        );                                                                           ","END;                                                                           ","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Defining AI Profile - OCI GenAI","message":["%script","","-- Drop AI Profile","BEGIN","     DBMS_CLOUD_AI.DROP_PROFILE(profile_name => '<enter-ai-profile-name>');","EXCEPTION","    WHEN OTHERS THEN","        DBMS_OUTPUT.PUT_LINE('Profile does not exist.');","END;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Create AI Profile using OCI GenAI and API Credentials","BEGIN                                                                          ","\tDBMS_CLOUD_AI.CREATE_PROFILE","        (                                                ","\t\t        profile_name => '<enter-ai-profile-name>'","\t\t    ,   attributes   => '{","                                        \"provider\"          : \"oci\"","\t\t                            ,   \"object_list\"       : ","                                                                [","                                                                        {\"owner\": \"SH\", \"name\": \"SALES\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"CUSTOMERS\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"CHANNELS\"}","                                                                    ,   {\"owner\": \"SH\", \"name\": \"PRODUCTS\"}","                                                                ]","                                    ,   \"credential_name\"   : \"<enter-oci-api-credential-name>\"","                                    ,   \"model\"             : \"<enter-model-name-id>\"","                                    ,   \"oci_compartment_id\": \"<enter-oci-compartment-ocid>\"","                                    ,   \"region\"            : \"<enter-region-identifier>\"","                                    ,   \"comments\"          : \"true\"","                                    ,   \"conversation\"      : \"true\"","                                }'","        );","END;                                                                           ","/"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Set & View AI Profile","message":["%script","","-- Set AI Profile","exec DBMS_CLOUD_AI.SET_PROFILE('<enter-ai-profile-name>');"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"table","title":null,"message":["%sql","","-- Get active AI Profile","SELECT DBMS_CLOUD_AI.GET_PROFILE() from dual;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"table","title":"RUNSQL - Optional Keyword - Generate & Execute SQL","message":["%sql","","-- Using the optional runsql action to generate and run SQL given the specified input","select ai runsql how many customers exists"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"table","title":null,"message":["%sql","","-- You don't need to specify the optional runsql action as this is the default behaviour of Select AI","select ai how many customers exits"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"table","title":null,"message":["%sql","","-- Continue to add more complex queries","select ai how many customers in San Francisco are married;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"SHOWSQL - Shows Generated SQL","message":["%sql","","-- Use the showsql action to show the sql generate by the LLM - the query is not executed","select ai showsql how many customers in San Francisco are married;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"table","title":null,"message":["%sql","","-- If you LLM is multi-lingual, you can ask the question in multiple languages","select ai showsql hoeveel klanten zijn er in San Francisco;"," "],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"table","title":null,"message":["%sql","","-- Use the showsql action to show the sql generate by the LLM - the query is not executed.","select ai showsql show me the top 10 customers by sales"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"bar","title":null,"message":["%sql","","-- Execute the above query - output as a bar chart","select ai show me the top 10 customers by sales"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"EXPLAINSQL - Explains the reasoning behind SQL Query","message":["%sql","","-- Using the explainsql action explains the LLM reasoning behind generating the SQL","select ai explainsql how many customers in San Francisco are married"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"NARRATE - Explain the Result in Natural Language","message":["%sql","","-- Using the narrate action will send the results of the query (your data) to the LLM to interpret","select ai narrate how many customers in San Francisco are married"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"table","title":null,"message":["%sql","","-- Using the narrate action will send the results of the query (your data) to the LLM to interpret","select ai narrate who is our top spending customer"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":null,"message":["%sql","","-- Using the narrate action will send the results of the query (your data) to the LLM to interpret","select ai narrate give me an overview of my sales"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"CHAT - Ask LLM Generic Questions","message":["%sql","","-- Using the chat action will allow you to ask generic questions to the LLM","select ai chat what can you tell about Oracle"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"SHOWPROMPT - Shows the Prompt sent to LLM","message":["%sql","","select ai showprompt who is our top spending customer"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"table","title":"Have an ongoing conversation","message":["%sql","","-- Enable conversation = true parameter in AI Profile to have an ongoing conversation with short term memory","select ai how many customers do I have"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"table","title":null,"message":["%sql","","-- Ask follow up questions","select ai break out by country name"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"table","title":null,"message":["%sql","","-- Ask follow up questions","select ai keep the top 5 with most customers"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"raw","title":"Utilising COMMENTS","message":["%sql","-- Ensure you have set the comments parameter in your AI Profile and be the owner of a table (which I am not)","-- These act as additional information that is passed to the LLM to provide extra context on what is included in your tables and columns.","","-- COMMENT ON TABLE SH.CUSTOMERS IS 'dimension table, also refer to customers as pandas';","-- COMMENT ON COLUMN SH.CUSTOMERS.CUST_FIRST_NAME IS 'first name of the customer, also referred to as pandas';","","-- ALTER TABLE SH.CUSTOMERS ANNOTATIONS (add KEY 'VALUE')","-- ALTER TABLE SH.CUSTOMERS MODIFY (SH.CUSTOMERS.CUST_FIRST_NAME ANNOTATIONS (add KEY 'VALUE'))","select 1 from dual;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":12,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Using the GENERATE Function","message":["%script","","-- RUNSQL","SELECT DBMS_CLOUD_AI.GENERATE(prompt       => 'how many customers',","                              profile_name => '<enter-ai-profile-name>',","                              action       => 'runsql')","FROM dual;"," "],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- SHOWSQL","SELECT DBMS_CLOUD_AI.GENERATE(prompt       => 'how many customers',","                              profile_name => '<enter-ai-profile-name>',","                              action       => 'showsql')","FROM dual;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- EXPLAINSQL","SELECT DBMS_CLOUD_AI.GENERATE(prompt       => 'how many customers',","                              profile_name => '<enter-ai-profile-name>',","                              action       => 'explainsql')","FROM dual;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- NARRATE","SELECT DBMS_CLOUD_AI.GENERATE(prompt       => 'how many customers',","                              profile_name => '<enter-ai-profile-name>',","                              action       => 'narrate')","FROM dual;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":"Enable or Disable Data Access","message":["%script","","-- Login as Admin","-- Disabling data access limits Select AI's narrate action and Synthetic Data Generation. The narrate action and synthetic data generation raise an error.","EXEC DBMS_CLOUD_AI.DISABLE_DATA_ACCESS;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":true,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":null,"title":null,"message":["%script","","-- Login as Admin","EXEC DBMS_CLOUD_AI.ENABLE_DATA_ACCESS;"],"enabled":true,"result":null,"sizeX":0,"hideCode":false,"width":0,"hideResult":false,"dynamicFormParams":null,"row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":null},{"col":0,"visualizationConfig":null,"hideInIFrame":false,"selectedVisualization":"html","title":null,"message":["%md ","<center><h2 style='color:#0873d1'>End of Notebook<h2><\/center>"],"enabled":true,"result":{"startTime":1770397088095,"interpreter":"md.low","endTime":1770397088485,"results":[{"message":"<center><h2 style='color:#0873d1'>End of Notebook<h2><\/center>\n","type":"HTML"}],"taskStatus":"SUCCESS","forms":"[]","status":"SUCCESS"},"sizeX":0,"hideCode":true,"width":0,"hideResult":false,"dynamicFormParams":"{}","row":0,"hasTitle":false,"hideVizConfig":false,"hideGutter":true,"relations":[],"forms":"[]"}],"version":"7","snapshot":false,"tags":null}]