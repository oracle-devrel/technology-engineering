# OCI Configuration for SOC Detection Rules
# Copy this file to .env.local and fill in your values:
#   cp .env.local.example .env.local
#
# These override the hardcoded defaults in scripts/oci_config.py.
# Environment variables (OCI_TENANCY_ID, etc.) take highest priority.

OCI_TENANCY_ID=ocid1.tenancy.oc1..your-tenancy-ocid-here
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..your-compartment-ocid-here

# Optional: OCI CLI profile name (default: DEFAULT)
# OCI_PROFILE=DEFAULT

# Optional: OCI region (default: from ~/.oci/config)
# OCI_REGION=us-phoenix-1

# Optional: longer Log Analytics field inventory timeout for large namespaces.
# OCI_LOG_ANALYTICS_READ_TIMEOUT_SECONDS=180

# Optional: profile-scoped overrides for multi-profile demo environments.
# These are used when OCI_PROFILE matches the prefix, so a DEFAULT run does not
# inherit cap tenancy, compartment, namespace, or log group values.
# DEFAULT_OCI_TENANCY_ID=ocid1.tenancy.oc1..default-tenancy-ocid
# DEFAULT_OCI_COMPARTMENT_ID=ocid1.compartment.oc1..default-observability-compartment
# DEFAULT_LA_NAMESPACE=default-la-namespace
# DEFAULT_LOG_ANALYTICS_LOG_GROUP_ID=ocid1.loganalyticsloggroup.oc1.region.default-log-group
# CAP_OCI_TENANCY_ID=ocid1.tenancy.oc1..cap-tenancy-ocid
# CAP_OCI_COMPARTMENT_ID=ocid1.compartment.oc1..cap-observability-compartment
# CAP_LA_NAMESPACE=cap-la-namespace
# CAP_LOG_ANALYTICS_LOG_GROUP_ID=ocid1.loganalyticsloggroup.oc1.region.cap-log-group
