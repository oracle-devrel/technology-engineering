{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SIEM Migration Readiness Report",
  "type": "object",
  "required": ["version", "generated_at", "platform", "summary", "items"],
  "properties": {
    "version": {"type": "string"},
    "generated_at": {"type": "string"},
    "inventory_generated_at": {"type": "string"},
    "platform": {"type": "string"},
    "report_path": {"type": "string"},
    "summary": {
      "type": "object",
      "required": ["content_count", "ready_for_local_validation_count", "blocked_count", "blocker_counts"],
      "properties": {
        "content_count": {"type": "integer", "minimum": 0},
        "ready_for_local_validation_count": {"type": "integer", "minimum": 0},
        "blocked_count": {"type": "integer", "minimum": 0},
        "status_counts": {"type": "object"},
        "blocker_counts": {"type": "object"},
        "feed_dependency_count": {"type": "integer", "minimum": 0}
      }
    },
    "items": {"type": "array"}
  }
}
