{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SIEM Discovery Inventory",
  "type": "object",
  "required": ["version", "generated_at", "platform", "summary", "items"],
  "properties": {
    "version": {"type": "string"},
    "generated_at": {"type": "string"},
    "platform": {"type": "string"},
    "source": {"type": "object"},
    "summary": {
      "type": "object",
      "required": ["content_count", "enabled_count", "blocked_count"],
      "properties": {
        "content_count": {"type": "integer", "minimum": 0},
        "enabled_count": {"type": "integer", "minimum": 0},
        "blocked_count": {"type": "integer", "minimum": 0},
        "ready_for_local_validation_count": {"type": "integer", "minimum": 0},
        "top_source_tables": {"type": "object"},
        "blocker_counts": {"type": "object"},
        "feed_dependency_count": {"type": "integer", "minimum": 0}
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "content_id",
          "kind",
          "source_path",
          "enabled",
          "severity",
          "schedule",
          "connectors",
          "source_tables",
          "field_usage",
          "mapped_oci_sources",
          "missing_tables",
          "missing_fields",
          "hit_counts_by_lookback",
          "stored_log_volume_bytes",
          "retention_days",
          "dashboard_references",
          "migration_status",
          "blockers"
        ],
        "properties": {
          "content_id": {"type": "string"},
          "title": {"type": "string"},
          "kind": {"type": "string"},
          "source_path": {"type": "string"},
          "source_url": {"type": "string"},
          "enabled": {"type": "boolean"},
          "severity": {"type": "string"},
          "schedule": {"type": "object"},
          "connectors": {"type": "array"},
          "source_tables": {"type": "array", "items": {"type": "string"}},
          "field_usage": {"type": "array", "items": {"type": "string"}},
          "mapped_oci_sources": {"type": "array", "items": {"type": "string"}},
          "missing_tables": {"type": "array", "items": {"type": "string"}},
          "missing_fields": {"type": "array", "items": {"type": "string"}},
          "hit_counts_by_lookback": {"type": "object"},
          "stored_log_volume_bytes": {"type": "integer", "minimum": 0},
          "retention_days": {"type": "integer", "minimum": 0},
          "dashboard_references": {"type": "array"},
          "feed_dependencies": {"type": "array"},
          "migration_status": {"type": "string"},
          "blockers": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["type", "detail"],
              "properties": {
                "type": {
                  "enum": [
                    "field_mapping",
                    "table_mapping",
                    "local_validation",
                    "live_validation",
                    "live_environment",
                    "kql_support",
                    "unsupported",
                    "parser_readiness"
                  ]
                },
                "detail": {"type": "string"}
              }
            }
          }
        }
      }
    }
  }
}
