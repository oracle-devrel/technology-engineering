{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://oci-logan.local/schemas/logan_workbench/command_reference.schema.json",
  "type": "object",
  "required": ["schema_version", "generated_at", "sources", "required_commands", "commands"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "generated_at": { "type": "string" },
    "sources": { "type": "array", "items": { "type": "string", "format": "uri" }, "minItems": 2 },
    "required_commands": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "commands": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "category", "source_url", "retrieved_at", "summary", "syntax", "examples", "notes", "provenance"],
        "properties": {
          "name": { "type": "string", "pattern": "^[a-z][a-z0-9_-]*$" },
          "category": { "type": "string" },
          "source_url": { "type": "string", "format": "uri" },
          "source_title": { "type": "string" },
          "retrieved_at": { "type": "string" },
          "summary": { "type": "string", "minLength": 1 },
          "syntax": { "type": "string", "minLength": 1 },
          "examples": { "type": "array", "items": { "type": "string" } },
          "notes": { "type": "array", "items": { "type": "string" } },
          "provenance": { "type": "object" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
