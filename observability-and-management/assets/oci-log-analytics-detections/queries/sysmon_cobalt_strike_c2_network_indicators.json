{
  "title": "Sysmon Cobalt Strike C2 Network Indicators",
  "description": "Detects network connections from processes commonly associated with Cobalt Strike beacon activity. Includes default Cobalt Strike process injection targets and malleable C2 patterns.\n",
  "query": "('Log Source' = 'Windows Sysmon Events' or 'Log Source' = 'Windows Sysmon Operational Logs' or 'Log Source' = 'SOC Sysmon Network Logs' or 'Log Source' = 'SOC Windows Sysmon Logs') and (( (('Process Name' like '*\\\\beacon.exe' or 'Process Name' like '*\\\\cobaltstrike.exe') and Initiated = 'true') or (('Process Name' like '*\\\\rundll32.exe' or 'Process Name' like '*\\\\dllhost.exe' or 'Process Name' like '*\\\\svchost.exe' or 'Process Name' like '*\\\\explorer.exe') and Initiated = 'true' and ('Destination Port' = 80 or 'Destination Port' = 443 or 'Destination Port' = 8080 or 'Destination Port' = 8443 or 'Destination Port' = 50050)) ) and not (('Destination IP' like '10.*' or 'Destination IP' like '172.16.*' or 'Destination IP' like '192.168.*' or 'Destination IP' like '127.*')))",
