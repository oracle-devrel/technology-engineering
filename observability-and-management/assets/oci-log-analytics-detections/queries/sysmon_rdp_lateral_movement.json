{
  "title": "Sysmon RDP Lateral Movement",
  "description": "Detects outbound RDP connections (port 3389) from unusual processes. While RDP is commonly used for administration, connections from non-standard processes may indicate lateral movement.\n",
  "query": "('Log Source' = 'Windows Sysmon Events' or 'Log Source' = 'Windows Sysmon Operational Logs' or 'Log Source' = 'SOC Sysmon Network Logs' or 'Log Source' = 'SOC Windows Sysmon Logs') and (('Destination Port' = 3389 and Initiated = 'true') and (('Process Name' like '*\\\\cmd.exe' or 'Process Name' like '*\\\\powershell.exe' or 'Process Name' like '*\\\\wscript.exe' or 'Process Name' like '*\\\\mstsc.exe' or 'Process Name' like '*\\\\tscon.exe')))",
