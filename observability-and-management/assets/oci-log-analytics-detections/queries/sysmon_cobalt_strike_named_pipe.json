{
  "title": "Sysmon Cobalt Strike Named Pipe",
  "description": "Detects named pipe creation matching known Cobalt Strike default patterns. Cobalt Strike uses named pipes for inter-process communication and lateral movement via SMB beacon.\n",
  "query": "('Log Source' = 'Windows Sysmon Events' or 'Log Source' = 'Windows Sysmon Operational Logs' or 'Log Source' = 'SOC Windows Sysmon Logs') and ((('Pipe Name' like '\\\\MSSE-*' or 'Pipe Name' like '\\\\postex_*' or 'Pipe Name' like '\\\\postex_ssh_*' or 'Pipe Name' like '\\\\status_*' or 'Pipe Name' like '\\\\msagent_*')) or (('Pipe Name' like '*\\\\interprocess_*' or 'Pipe Name' like '*\\\\mojo.*' or 'Pipe Name' like '*\\\\chrome.*' or 'Pipe Name' like '*\\\\DserNamePipe*' or 'Pipe Name' like '*\\\\winsock*' or 'Pipe Name' like '*\\\\UIA_PIPE*')))",
  "sigma_id": "a1b2c3d4-7002-4000-8000-000000000001",
  "level": "critical",
  "stig_category": "CAT I",
