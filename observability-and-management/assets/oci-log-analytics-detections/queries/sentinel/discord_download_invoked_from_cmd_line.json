{
  "title": "Discord download invoked from cmd line",
  "description": "'This hunting query looks for hosts that have attempted to interact with the Discord CDN. This activity is not normally invoked from the command line and could indicate C2, exfiltration, or malware delivery activity.'\n",
  "query": "('Log Source' = 'Windows Security Events' or 'Log Source' = 'Windows Event Security Logs') and ('Event ID' = '4688') and (('Process Name' like '*powershell.exe*' or 'Process Name' like '*powershell_ise.exe*' or 'Process Name' like '*cmd.exe*') or 'Command Line' like '*powershell*') and (('Command Line' like '*cdn.discordapp.com*' or 'Command Line' like '*moc.ppadrocsid.ndc*')) | fields Time, Entity, User, 'Process Name', 'Command Line'",
  "level": "medium",
  "source_type": "microsoft_sentinel",
  "sentinel_id": "e7dd442a-0af8-48eb-8358-9e91f4911849",
