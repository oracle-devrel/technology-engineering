{
  "title": "NRT Base64 Encoded Windows Process Command-lines",
  "description": "'This detection identifies instances of a base64 encoded PE file header seen in the process command line parameter.'\n",
  "query": "('Log Source' = 'Windows Security Events' or 'Log Source' = 'Windows Event Security Logs') and ('Event ID' = '4688') and (('Command Line' != null and 'Command Line' != '')) and ('Command Line' like '*TVqQAAMAAAAEAAA*')",
