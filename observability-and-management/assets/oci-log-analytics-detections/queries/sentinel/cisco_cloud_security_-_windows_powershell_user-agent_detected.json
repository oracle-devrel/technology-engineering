  "title": "Cisco Cloud Security - Windows PowerShell User-Agent Detected",
  "description": "'Rule helps to detect Powershell user-agent activity by an unusual process other than a web browser.'\n",
  "query": "('Log Source' = 'SOC WAF Security Logs' or 'Log Source' = 'SOC Web Application Logs' or 'Log Source' = 'SOC Network Firewall Logs') and ('Event Type' = 'proxylogs') and ('User Agent' like '*WindowsPowerShell*') | eval Message = 'Windows PowerShell User Agent' | fields Time, Message, 'Source IP', 'Destination IP', 'Request URL', 'User Agent'",
