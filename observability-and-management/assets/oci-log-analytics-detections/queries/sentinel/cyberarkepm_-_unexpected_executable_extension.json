  "title": "CyberArkEPM - Unexpected executable extension",
  "description": "'Detects Windows executable with unexpected extension.'\n",
  "query": "('Log Source' = 'SOC Windows Sysmon Logs' or 'Log Source' = 'Windows Security Events') and ('Event Type' != 'AttackAttempt') and ('Parent Process Name' like '*\\\\*') and (not ('Parent Process Name' like '*.exe')) | fields Time, Description, 'User Name', 'Parent Process Name'",
