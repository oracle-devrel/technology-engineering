# Local-only variables for paid provisioning and service registration.
# Copy to .env.local, chmod 600 it, and never commit the real file.

# DBCS provisioning.
TF_VAR_db_admin_password="<SET_A_STRONG_PASSWORD>"
TF_VAR_ssh_public_keys='["ssh-rsa <PUBLIC_KEY_MATERIAL> <COMMENT>"]'
TF_VAR_create_identity_policy=false

# Autonomous Database provisioning, if using `init-region --target-kind autonomous`.
TF_VAR_adb_admin_password="<SET_A_STRONG_PASSWORD>"

# Optional Data Safe / Vault secret flows.
DBMAN_OPSI_MONITORING_PASSWORD="<SET_MONITORING_USER_PASSWORD>"
DBMAN_OPSI_DATA_SAFE_PASSWORD="<SET_DATA_SAFE_USER_PASSWORD>"
