OCI_COMPARTMENT_ID=YOUR_COMPARTMENT_OCID
GENAI_ENDPOINT=https://inference.generativeai.eu-frankfurt-1.oci.oraclecloud.com
GENAI_REGION=eu-frankfurt-1
OCI_CONFIG_FILE=~/.oci/config
OCI_CONFIG_PROFILE=DEFAULT
DEFAULT_MODEL_ID=google.gemini-2.5-flash
MAX_UPLOAD_MB=37
ALLOWED_ORIGIN_REGEX=https?://(localhost|127\.0\.0\.1)(:\d+)?
OCI_VIDEO_STUDIO_ENV_FILE=

# Model pricing and feature metadata. These are non-secret values loaded by
# the backend model catalog each server run. Prices are USD per 1M tokens.
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_INPUT_PRICE_PER_MILLION=1.25
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_OUTPUT_PRICE_PER_MILLION=10
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_LONG_CONTEXT_INPUT_PRICE_PER_MILLION=2.5
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_LONG_CONTEXT_OUTPUT_PRICE_PER_MILLION=15
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_LONG_CONTEXT_THRESHOLD_TOKENS=200000
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_PRICE_CURRENCY=USD
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_PRICING_SOURCE=oracle_price_list
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_INPUT_MODALITIES=text,image,video,audio
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_OUTPUT_MODALITIES=text
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_MAX_INPUT_TOKENS=1048576
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_MAX_OUTPUT_TOKENS=65536
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_SUPPORTS_TOOLS=true
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_STRUCTURED_OUTPUT=true
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_CONTEXT_CACHING=true
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_THINKING=true
OCI_VIDEO_MODEL_GOOGLE_GEMINI_2_5_PRO_FEATURE_SOURCE=oracle_model_docs

