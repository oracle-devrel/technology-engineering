resource "oci_database_db_system" "test_db_system" {
  availability_domain  = local.last_ad_name
  compartment_id       = local.compartment.id
  cpu_core_count = "2"
  data_storage_size_in_gb = "256"
  database_edition = "ENTERPRISE_EDITION"
  db_home {
    db_version = "23.9.0.25.07"
    display_name = "tfDbHome1"
    database {
      admin_password = "BEstrO0ng_#11"
      character_set = "AL32UTF8"
      db_name = "tfDb"
      db_workload = "OLTP"
    #  kms_key_id = var.kms_key_id
    #  kms_key_version_id = var.kms_key_version_id
      ncharacter_set = "AL16UTF16"
      pdb_name = "tfPdb1"
    #  vault_id = var.vault_id
    }
  }
  db_system_options {
    storage_management = "LVM"
  }
  disk_redundancy = "NORMAL"
  display_name = "tfDbSystem"
  domain = "katogana.de"
  #fault_domains = ["FAULT-DOMAIN-1"]
  hostname = "tfOracleDb"
  #license_model = "LICENSE_INCLUDED"
  license_model = "BRING_YOUR_OWN_LICENSE"
  #license_model = "help me!"
  node_count = "1"
  shape = "VM.Standard2.2"
  ssh_public_keys = ["ssh-rsa  lange@Moloko"]
  subnet_id = oci_core_subnet.public_subnet.id
}
